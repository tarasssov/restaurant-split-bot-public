BOT_TOKEN=123456:telegram_token_here
TIP_PERCENT=10

# OCR
OCR_PROVIDER=yandex
YANDEX_FOLDER_ID=your_folder_id
YANDEX_VISION_API_KEY=your_vision_api_key

# LLM
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_PROXY_URL=socks5h://127.0.0.1:11080
LLM_MAX_CALLS_PER_RECEIPT=3
LLM_OCR_EXCERPT_CHARS=9000
LLM_GROUNDING_STRICT=1
LLM_MAX_UNSUPPORTED_RATIO=0.10
LLM_MAX_NOVEL_TOKEN_RATIO=0.05

# Weekly quality alert
QUALITY_ALERT_ENABLED=1
QUALITY_ALERT_WEEKDAY=MON
QUALITY_ALERT_HOUR=10
QUALITY_ALERT_TZ=Europe/Moscow
QUALITY_ALERT_MIN_NEW_FAILS=1
QUALITY_ALERT_CHAT_ID=123456789
QUALITY_ALERT_BOT_TOKEN=123456:alert_bot_token_here
QUALITY_ALERT_PROJECT_NAME=restaurant-split-bot
QUALITY_ALERT_PROXY_URL=socks5h://127.0.0.1:11080

# Webhook mode (for production server)
WEBHOOK_BASE_URL=https://bot.example.com
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET=change_me_random_string
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8080
